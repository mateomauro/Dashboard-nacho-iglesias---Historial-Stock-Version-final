# Copiá este archivo como `.env` y completá los valores reales.
# El `.env` NO se commitea (está en .gitignore).

# Supabase (datos de stock + autenticación)
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key

# Google Sheets (movimientos) — sólo para generar el PDF en local.
# Alternativamente, dejá el JSON de la service account un nivel arriba del proyecto.
# GOOGLE_SHEETS_CREDENTIALS_JSON={"type":"service_account", ...}
